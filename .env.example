# Reddit data is now fetched via Reddit's public JSON API — no credentials needed!
# https://www.reddit.com/r/{subreddit}/hot.json works without any API key.

# LLM API credentials (provide at least one — priority: Anthropic > OpenAI > OpenRouter)

# Anthropic Claude API (Preferred)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI API (Alternative)
OPENAI_API_KEY=your_openai_api_key

# OpenRouter API (Free alternative — supports many models)
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Database setting (optional, defaults to app.db in project root)
DATABASE_URL=sqlite:///app/database.db
